{
  "expo": {
    "scheme": "hittrack",
    "name": "Hittrack",
    "slug": "Hittrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "HitTrack needs camera access to track your boxing movements.",
        "NSMicrophoneUsageDescription": "HitTrack needs microphone access to record your training sessions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.wildbout.hittrack"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bd853420-3659-4dba-b516-f8771a4e8666"
      }
    }
  }
}